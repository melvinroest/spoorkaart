{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spoorkaart track geometry per serie route",
  "type": "object",
  "required": ["schemaVersion", "page", "timeWindow", "series"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": 1},
    "page": {"enum": [1, 2, 3, 4]},
    "timeWindow": {"type": "string"},
    "series": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["routes"],
        "additionalProperties": false,
        "properties": {
          "routes": {
            "type": "array",
            "items": {
              "anyOf": [
                {"type": "null"},
                {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "type": "array",
                    "prefixItems": [
                      {"type": "number", "minimum": 44, "maximum": 59},
                      {"type": "number", "minimum": -3, "maximum": 17}
                    ],
                    "items": false,
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              ]
            }
          }
        }
      }
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
