{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spoorkaart shared station vocabulary",
  "type": "object",
  "required": ["schemaVersion", "source", "stations"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": 1},
    "source": {"type": "string"},
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/station"}
    }
  },
  "$defs": {
    "stationId": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "xy": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "latlon": {
      "type": "array",
      "prefixItems": [
        {"type": "number", "minimum": -90, "maximum": 90},
        {"type": "number", "minimum": -180, "maximum": 180}
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "station": {
      "type": "object",
      "required": ["id", "name", "country"],
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/stationId"},
        "name": {"type": "string", "minLength": 1},
        "nameAsPrinted": {"type": "string"},
        "country": {"enum": ["NL", "DE", "BE", "FR", "GB"]},
        "major": {"type": "boolean"},
        "coords": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "1": {"$ref": "#/$defs/xy"},
            "2": {"$ref": "#/$defs/xy"},
            "3": {"$ref": "#/$defs/xy"},
            "4": {"$ref": "#/$defs/xy"}
          }
        },
        "geo": {"$ref": "#/$defs/latlon"},
        "code": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1},
        "suspect": {"type": "boolean"}
      }
    }
  }
}
